# ============================================================
# SIG-Acueducto Labateca — Variables de Entorno
# Copiar este archivo como .env y completar los valores reales
# NUNCA commitear el archivo .env al repositorio
# ============================================================

# --- Base de datos PostgreSQL + PostGIS ---
DB_USER=siguser
DB_PASSWORD=CAMBIAR_POR_CLAVE_SEGURA
DB_NAME=sig_acueducto
DB_HOST=db
DB_PORT=5432

DATABASE_URL=postgresql+asyncpg://siguser:CAMBIAR_POR_CLAVE_SEGURA@db:5432/sig_acueducto
SYNC_DATABASE_URL=postgresql://siguser:CAMBIAR_POR_CLAVE_SEGURA@db:5432/sig_acueducto

# --- Autenticación JWT ---
SECRET_KEY=CAMBIAR_POR_CADENA_ALEATORIA_DE_64_CARACTERES
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- CORS (dominios permitidos, separados por coma) ---
ALLOWED_ORIGINS=http://localhost:5173,https://tu-dominio.easypanel.host

# --- Martin Tile Server ---
MARTIN_DATABASE_URL=postgresql://siguser:CAMBIAR_POR_CLAVE_SEGURA@db:5432/sig_acueducto

# --- Usuario administrador inicial (seed) ---
INITIAL_ADMIN_EMAIL=admin@acueducto-labateca.gov.co
INITIAL_ADMIN_PASSWORD=CAMBIAR_EN_PRODUCCION

# --- Frontend (Vite — usar VITE_ como prefijo) ---
VITE_API_URL=http://localhost:8000
VITE_TILES_URL=http://localhost:3000
